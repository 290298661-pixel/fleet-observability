    {
      "datasource": { "type": "loki", "uid": "loki" },
      "description": "跨所有日志的全文搜索。使用 LogQL 过滤器深入查看。点击日志行可查看完整上下文。",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "custom": {
            "align": "auto",
            "cellOptions": { "type": "auto" },
            "filterable": true,
            "inspect": false
          },
          "mappings": [],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "text", "value": null }] }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "level" },
            "properties": [
              {
                "id": "mappings",
                "value": [
                  { "options": { "error": { "color": "red", "index": 0, "text": "ERROR" }, "ERROR": { "color": "red", "index": 1, "text": "ERROR" } }, "type": "value" },
                  { "options": { "warn": { "color": "yellow", "index": 2, "text": "WARN" }, "WARNING": { "color": "yellow", "index": 3, "text": "WARNING" } }, "type": "value" },
                  { "options": { "info": { "color": "blue", "index": 4, "text": "INFO" }, "INFO": { "color": "blue", "index": 5, "text": "INFO" } }, "type": "value" },
                  { "options": { "debug": { "color": "grey", "index": 6, "text": "DEBUG" }, "DEBUG": { "color": "grey", "index": 7, "text": "DEBUG" } }, "type": "value" }
                ]
              },
              { "id": "custom.cellOptions", "value": { "type": "color-background" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Line" },
            "properties": [
              { "id": "custom.width", "value": 600 }
            ]
          }
        ]
      },
      "gridPos": { "h": 16, "w": 24, "x": 0, "y": 18 },
      "id": 5,
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": true,
        "showCommonLabels": false,
        "showLabels": true,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": true
      },
      "pluginVersion": "10.0.0",
      "targets": [
        {
          "expr": "{app=~\"$app\"} |~ \"$search\"",
          "legendFormat": "{{app}}",
          "maxLines": 500,
          "refId": "A"
        }
      ],
      "title": "日志查看器",
      "type": "logs"
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["fleet-observability", "logs"],
  "templating": {
    "list": [
      {
        "current": { "selected": true, "text": "全部", "value": "$__all" },
        "datasource": { "type": "loki", "uid": "loki" },
        "definition": "label_values(app)",
        "hide": 0,
        "includeAll": true,
        "label": "应用",
        "multi": true,
        "name": "app",
        "options": [],
        "query": { "query": "label_values(app)", "refId": "StandardVariableQuery" },
        "refresh": 1,
        "regex": "^(game-fleet-director-.*|node-health-watcher|node-guardian|loki|prometheus)$",
        "skipUrlSync": false,
        "sort": 1,
        "type": "query"
      },
      {
        "current": { "selected": false, "text": "", "value": "" },
        "hide": 0,
        "label": "搜索（正则）",
        "name": "search",
        "options": [
          { "selected": true, "text": "全部日志", "value": "" },
          { "selected": false, "text": "仅错误", "value": "(?i)error|fail|fatal|panic" },
          { "selected": false, "text": "仅警告", "value": "(?i)warn" },
          { "selected": false, "text": "扩缩容事件", "value": "(?i)scale|scaling" },
          { "selected": false, "text": "分配", "value": "(?i)allocat" },
          { "selected": false, "text": "熔断器", "value": "(?i)circuit.breaker" },
          { "selected": false, "text": "健康检查", "value": "(?i)health|inspection" }
        ],
        "query": "",
        "skipUrlSync": false,
        "type": "custom"
      },
      {
        "current": { "selected": false, "text": "全部", "value": "$__all" },
        "datasource": { "type": "loki", "uid": "loki" },
        "definition": "label_values(level)",
        "hide": 0,
        "includeAll": true,
        "label": "级别",
        "multi": true,
        "name": "level",
        "options": [],
        "query": { "query": "label_values(level)", "refId": "StandardVariableQuery" },
        "refresh": 1,
        "regex": "",
        "skipUrlSync": false,
        "sort": 0,
        "type": "query"
      }
    ]
  },
